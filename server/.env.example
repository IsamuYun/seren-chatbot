# Port this app itself listens on (kept away from AnythingLLM's default 3001
# to avoid a collision when both run on the same host).
PORT=4000

# Base URL of your AnythingLLM Docker instance (no trailing slash).
# - If AnythingLLM also runs in Docker on the same docker-compose network,
#   use its service name, e.g. http://anythingllm:3001
# - If AnythingLLM runs directly on the host (outside this compose file),
#   use http://host.docker.internal:3001 when this app itself runs in Docker,
#   or http://localhost:3001 when running this app directly with `npm run dev`.
ANYTHINGLLM_BASE_URL=http://localhost:3001

# Developer API key generated in AnythingLLM > Settings > Developer API
ANYTHINGLLM_API_KEY=

# The workspace slug to chat against (visible in the workspace settings URL)
ANYTHINGLLM_WORKSPACE_SLUG=
